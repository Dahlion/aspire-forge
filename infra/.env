# Seacoast DevOps — local dev environment
# Values are hardcoded here and mirrored in docker-compose.yml / appsettings.Development.json

# Postgres
POSTGRES_DB=dbSeacoastDevops
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
