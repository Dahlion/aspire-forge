{
  "realm": "aspireforge",
  "displayName": "AspireForge",
  "enabled": true,
  "loginTheme": "seacoast-devops-theme",
  "accountTheme": "seacoast-devops-theme",
  "adminTheme": "seacoast-devops-theme",
  "emailTheme": "seacoast-devops-theme",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "roles": {
    "realm": [
      {
        "name": "seacoast_owneradmin",
        "description": "Full administrative access across all tenants and subscriptions."
      },
      {
        "name": "subscription_manager",
        "description": "Can manage tenant subscriptions."
      },
      {
        "name": "tenant_admin",
        "description": "Can administer a specific tenant."
      },
      {
        "name": "tenant_user_manager",
        "description": "Can manage users within a tenant."
      },
      {
        "name": "tenant_viewer",
        "description": "Read-only tenant access."
      }
    ]
  },

  "groups": [
    {
      "name": "platform",
      "subGroups": [
        {
          "name": "admins",
          "realmRoles": [
            "seacoast_owneradmin",
            "subscription_manager"
          ]
        }
      ]
    },
    {
      "name": "tenants",
      "subGroups": [
        {
          "name": "lisbon-ems",
          "attributes": {
            "tenant_id": ["a1b2c3d4-e5f6-7890-abcd-ef1234567890"],
            "tenant_name": ["Lisbon EMS"],
            "subscription_plan": ["professional"],
            "subscription_status": ["active"]
          },
          "subGroups": [
            {
              "name": "admins",
              "realmRoles": [
                "tenant_admin",
                "tenant_user_manager"
              ]
            },
            {
              "name": "viewers",
              "realmRoles": [
                "tenant_viewer"
              ]
            }
          ]
        },
        {
          "name": "seacoast-internal",
          "attributes": {
            "tenant_id": ["f0e1d2c3-b4a5-9687-fedc-ba9876543210"],
            "tenant_name": ["Seacoast Internal"],
            "subscription_plan": ["enterprise"],
            "subscription_status": ["active"],
            "billing_cycle": ["annual"],
            "max_users": ["25"]
          },
          "subGroups": [
            {
              "name": "admins",
              "realmRoles": [
                "tenant_admin",
                "tenant_user_manager"
              ]
            },
            {
              "name": "viewers",
              "realmRoles": [
                "tenant_viewer"
              ]
            }
          ]
        }
      ]
    }
  ],

  "clientScopes": [
    {
      "name": "api-audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "web",
      "name": "Seacoast DevOps Admin Portal Web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "https://localhost:5173/*",
        "http://localhost:5000/signin-oidc",
        "https://localhost:5001/signin-oidc"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "https://localhost:5173",
        "http://localhost:5000",
        "https://localhost:5001"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "api-audience"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "api",
      "name": "AspireForge API",
      "enabled": true,
      "bearerOnly": true
    }
  ],

